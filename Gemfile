source "https://rubygems.org"

# Mirrors the gem versions GitHub Pages uses for its native build, so local
# previews match production. https://pages.github.com/versions/
gem "github-pages", group: :jekyll_plugins

# Tzinfo data for platforms (Windows/JRuby) that lack a system zoneinfo db.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
gem "wdm", "~> 0.1", platforms: [:mingw, :mswin, :x64_mingw]
